DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/coindcx
COINDCX_API_KEY=YOUR_API_KEY
COINDCX_SECRET_KEY=YOUR_SECRET_KEY

BOT_MODE=paper
TRADE_MARKETS=BTCINR,ETHINR

TRADE_SIZE=40
PROFIT_TARGET_PERCENT=0.6
DIP_BUY_PERCENT=0.3
STOP_LOSS_PERCENT=0.9
REPRICE_INTERVAL_MS=7000
REPRICE_THRESHOLD_PERCENT=0.3
MAKER_BUFFER_PERCENT=0.08
AUTO_SELL_ENABLED=true
AUTO_MARKET_SELECTION=false
AUTO_MARKET_SELECTION_COUNT=8
AUTO_MARKET_REFRESH_MS=120000

MAX_POSITION_SIZE=200
MAX_OPEN_ORDERS=5
DAILY_LOSS_LIMIT=25

PORT=3000

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
REDIS_URL=
